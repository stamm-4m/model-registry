temperature = 298.22,
pH = 6.4472,
dissolved_oxygen_concentration = 30,
agitator = 100,
CO2_percent_in_off_gas = 0.089514,
oxygen_in_percent_in_off_gas = 0.19595,
vessel_volume = 58479,
sugar_feed_rate = 8
)
# Define the attributes for the input example (must match the model's training attributes)
attribute_names <- c("temperature", "pH", "dissolved_oxygen_concentration", "agitator",
"CO2_percent_in_off_gas", "oxygen_in_percent_in_off_gas",
"vessel_volume", "sugar_feed_rate")
# Create the FastVector object to store the attributes
fast_vector <- .jnew("weka/core/FastVector")
# Create Weka Attributes (numeric type) and add them to the FastVector
for (name in attribute_names) {
# Use Attribute.NUMERIC (instead of .jnull()) for numeric attributes
attribute <- .jnew("weka/core/Attribute", name, .jcast("weka/core/Attribute$Numeric", "java/lang/Object"))
fast_vector$add(attribute)  # Add to the FastVector
}

packageVersion("range")
packageVersion("ranger")
modelsEvaluation <- function(model, y ,testset,nameTestset) {
predictions <- predict(model, testset)
R2   <- cor(y, predictions)^2
MSE  <- mean((y - predictions)^2)
RMSE <- sqrt(MSE)
MAE  <- mean(abs(y - predictions))
print(nameTestset)
print(paste("R2:", R2, sep = " "))
print(paste("MSE:", MSE, sep = " "))
print(paste("RMSE:", RMSE, sep = " "))
print(paste("MAE:", MAE, sep = " "))
}
path = "C:/Users/corrales/Documents/IndPenSim/100_Batches_IndPenSim/"
Trainingset <- read.csv(file= paste0(path,"IndPenSim_trainingset.csv"), dec = "." , header = TRUE, sep =",", na.strings = "NA")
Testset     <- read.csv(file= paste0(path,"IndPenSim_testset.csv"), dec = "." , header = TRUE, sep =",", na.strings = "NA")
colnames(Trainingset)[4]   <- "temperature"
colnames(Testset)[4]       <- "temperature"
colnames(Trainingset)[5]   <- "pH"
colnames(Testset)[5]       <- "pH"
colnames(Trainingset)[6]   <- "dissolved_oxygen_concentration"
colnames(Testset)[6]       <- "dissolved_oxygen_concentration"
colnames(Trainingset)[7]   <- "agitator"
colnames(Testset)[7]       <- "agitator"
colnames(Trainingset)[8]   <- "CO2_percent_in_off_gas"
colnames(Testset)[8]       <- "CO2_percent_in_off_gas"
colnames(Trainingset)[9]   <- "oxygen_in_percent_in_off_gas"
colnames(Testset)[9]       <- "oxygen_in_percent_in_off_gas"
colnames(Trainingset)[10]  <- "vessel_volume"
colnames(Testset)[10]      <- "vessel_volume"
colnames(Trainingset)[11]  <- "sugar_feed_rate"
colnames(Testset)[11]      <- "sugar_feed_rate"
colnames(Trainingset)[12]  <- "penicillin_concentration"
colnames(Testset)[12]      <- "penicillin_concentration"
batch_ID = "64"
Batch_n <- Testset[ which(Testset$Batch.ID == batch_ID),]
##### ----->  Removing unused variables from dataset
Trainingset$Batch.ID  <- NULL
Trainingset$BatchType <- NULL
Trainingset$Time..h.  <- NULL
Batch_n$Batch.ID  <- NULL
Batch_n$BatchType <- NULL
Batch_n$Time..h.  <- NULL
library(Cubist)
cubistParameters <- cubistControl(rules = 15)#, extrapolation = 6)
CubistModel <- cubist(x = Trainingset[, -9], y = Trainingset$Penicillin ,
committees = 1,
control = cubistParameters)
CubistModel <- cubist(x = Trainingset[, -9], y = Trainingset$penicillin_concentration ,
committees = 1,
control = cubistParameters)
summary(CubistModel)
print(CubistModel)
# list the chosen features
predictors(CubistModel)
?predictors
modelsEvaluation(CubistModel,Batch_n$Penicillin ,Batch_n[,1:(ncol(Batch_n)-1)],paste0("CUBIST evaluation - batch: ",batch_ID))
modelsEvaluation(CubistModel,Batch_n$penicillin_concentration ,Batch_n[,1:(ncol(Batch_n)-1)],paste0("CUBIST evaluation - batch: ",batch_ID))
predictions <- predict(CubistModel, Batch_n)
print(predictions)
setwd("~/IndPenSim/Soft sensor construction/Models")
saveRDS(CubistModel, file = "0003_[R]_penicillin_CUBIST.rds")

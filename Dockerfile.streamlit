FROM python:3.12-slim

WORKDIR /app

# Install dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy everything (needed for Streamlit UI + assets + projects)
COPY . .

EXPOSE 8501

CMD ["streamlit", "run", "UI-FastApi.py", "--server.port=8501", "--server.address=0.0.0.0"]
